---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials', ({ data }) => !data.draft);
  return tutorials.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'tutorials'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter(h => h.depth <= 3);
---

<Base title={entry.data.title} description={entry.data.description}>
  <article data-pagefind-body>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={url('/tutorials')}>Tutorials</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>{entry.data.title}</span>
    </nav>

    <div class="prose-page">
      <p class="page-overline">Tutorial</p>
      <h1>{entry.data.title}</h1>

      <div class="post-meta">
        <time datetime={entry.data.pubDate.toISOString()}>
          {entry.data.pubDate.toLocaleDateString('en-GB', { dateStyle: 'long' })}
        </time>
        {entry.data.tags.length > 0 && (
          <ul class="tag-list" role="list">
            {entry.data.tags.map((tag: string) => <li class="tag">{tag}</li>)}
          </ul>
        )}
      </div>

      {tocHeadings.length > 0 && (
        <nav class="toc" aria-label="Table of contents">
          <p class="toc-title">Contents</p>
          <ul role="list">
            {tocHeadings.map(h => (
              <li style={`padding-left: ${(h.depth - 2) * 0.875}rem`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Base>
