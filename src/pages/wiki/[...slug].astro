---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import { url } from "../../lib/url";

export async function getStaticPaths() {
	const pages = await getCollection("wiki");
	return pages.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<"wiki">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const articleJsonLd = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: entry.data.title,
	description: entry.data.description,
	keywords: entry.data.tags,
	...(entry.data.lastUpdated
		? { dateModified: entry.data.lastUpdated.toISOString() }
		: {}),
	publisher: {
		"@type": "Organization",
		name: "CGIAR",
		url: "https://www.cgiar.org",
	},
};
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={entry.data.title} description={entry.data.description} jsonLd={articleJsonLd}>
  <article data-pagefind-body>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={url('/wiki')}>Wiki</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>{entry.data.title}</span>
    </nav>

    <div class="prose-page">
      <p class="page-overline">Reference</p>
      <h1>{entry.data.title}</h1>

      <div class="post-meta">
        {entry.data.lastUpdated
          ? <time datetime={entry.data.lastUpdated.toISOString()}>
              Updated {entry.data.lastUpdated.toLocaleDateString('en-GB', { dateStyle: 'long' })}
            </time>
          : <span>Reference document</span>
        }
        {entry.data.tags.length > 0 && (
          <ul class="tag-list" role="list">
            {entry.data.tags.map((tag: string) => <li class="tag">{tag}</li>)}
          </ul>
        )}
      </div>

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Base>
